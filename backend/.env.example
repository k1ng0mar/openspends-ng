# OpenSpends NG — Environment Configuration

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/openspends

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Mapbox
MAPBOX_TOKEN=

# GitHub (for issue creation)
GITHUB_TOKEN=

# App
APP_NAME=OpenSpends NG
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Rate Limiting
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_AUTH=1000

# Data Sources
GOVSPEND_BASE_URL=https://www.govspend.ng
BOF_BASE_URL=https://budgetoffice.gov.ng
NGF_BASE_URL=https://www.publicfinance.ngf.org.ng
